{
  "name": "gatsby-starter-default",
  "private": true,
  "description": "A simple starter to get up and developing quickly with Gatsby",
  "version": "0.1.0",
  "author": "Kyle Mathews <mathews.kyle@gmail.com>",
  "dependencies": {
    "@giscus/react": "^3.1.0",
    "@mdx-js/react": "^2.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "gatsby": "^5.14.6",
    "gatsby-plugin-image": "^3.16.0",
    "gatsby-plugin-manifest": "^5.14.0",
    "gatsby-plugin-mdx": "^5.16.0",
    "gatsby-plugin-sharp": "^5.16.0",
    "gatsby-plugin-sitemap": "^6.16.0",
    "gatsby-remark-images": "^7.16.0",
    "gatsby-source-filesystem": "^5.16.0",
    "gatsby-transformer-sharp": "^5.16.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rehype-pretty-code": "^0.14.3",
    "remark-gfm": "^3.0.1",
    "shiki": "^4.0.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "autoprefixer": "^10.4.24",
    "chokidar": "^5.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "gatsby-plugin-postcss": "^6.16.0",
    "postcss": "^8.5.6",
    "prettier": "^2.8.8",
    "puppeteer": "^24.37.4",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "gatsby"
  ],
  "license": "0BSD",
  "engines": {
    "node": ">=18.0.0 <23.0.0"
  },
  "overrides": {
    "msgpackr": "^1.11.2"
  },
  "scripts": {
    "prebuild": "node scripts/generate-content-index.js && node scripts/generate-search-documents.js",
    "build": "gatsby build",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "cf:d1:migrate:local": "wrangler d1 migrations apply my-blog --local",
    "cf:d1:migrate:remote": "wrangler d1 migrations apply my-blog --remote",
    "dev": "node scripts/run-gatsby-dev.js",
    "dev:watch": "node watch-mdx.js",
    "dev:watch:clean": "node watch-mdx.js --clean",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,css}\"",
    "start": "node scripts/run-gatsby-dev.js",
    "serve": "gatsby serve",
    "clean": "gatsby clean && node -e \"const fs=require('fs'); const f='content/content-index.json'; if(fs.existsSync(f)) fs.unlinkSync(f);\"",
    "index": "node scripts/generate-content-index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gatsbyjs/gatsby-starter-default"
  },
  "bugs": {
    "url": "https://github.com/gatsbyjs/gatsby/issues"
  }
}
