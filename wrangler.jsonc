{
  "name": "my-blog",
  "main": "worker/src/index.ts",
  "compatibility_date": "2026-04-13",
  "assets": {
    "directory": "./public"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "my-blog",
      "database_id": "4fa2030c-6259-4952-9b94-6c1903cc99e3"
    }
  ],
  "vectorize": [
    {
      "binding": "BLOG_SEARCH_INDEX",
      "index_name": "my-blog-search"
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "vars": {
    "GISCUS_REPO": "hyunbeanohh/ODDN-Blog",
    "GISCUS_CATEGORY_ID": "DIC_kwDORTJuH84C2ttM",
    "SEMANTIC_SEARCH_MODEL": "@cf/baai/bge-m3"
  }
}
